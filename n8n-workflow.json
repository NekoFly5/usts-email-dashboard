        "gmailOAuth2": {
          "id": "QRw4xl07PB0fY6Ik",
          "name": "Gmail account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const emails = items.map(item => {\n  const msg = item.json;\n\n  let from = '';\n  if (typeof msg.from === 'string') {\n    from = msg.from;\n  } else if (msg.from?.text) {\n    from = msg.from.text;\n  } else if (msg.from?.value?.[0]) {\n    const v = msg.from.value[0];\n    from = v.name ? `${v.name} <${v.address}>` : v.address || '';\n  }\n\n  const subject = msg.subject || '(sans objet)';\n  const date = msg.internalDate\n    ? new Date(Number(msg.internalDate)).toISOString()\n    : msg.date || new Date().toISOString();\n  const body = msg.text || msg.body?.text || msg.snippet || '';\n  const snippet = msg.snippet || body.substring(0, 200);\n\n  return { id: msg.id || '', from, subject, date, snippet, body };\n});\n\nreturn [{ json: { emails, count: emails.length } }];"
      },
      "id": "71f46bbf-7c27-43d6-8f32-76905464f5b2",
      "name": "Formater les emails",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        528,
        160
      ]
    },
    {
      "parameters": {
        "jsCode": "const emails = items[0].json.emails || [];\n\nconst staticData = $getWorkflowStaticData('global');\nstaticData.emails = JSON.stringify(emails);\n\nconst prompt = emails.length === 0\n  ? 'Aucun email reçu aujourd\\'hui.'\n  : emails.map((e, i) => `${i+1}. De: ${e.from}\\n   Objet: ${e.subject}\\n   Extrait: ${e.snippet?.substring(0,150)}`).join('\\n\\n');\n\nreturn [{ json: {\n  groqBody: JSON.stringify({\n    model: 'llama-3.3-70b-versatile',\n    messages: [\n      { role: 'system', content: 'Tu es un assistant qui résume des emails professionnels en français, de manière concise et structurée.' },\n      { role: 'user', content: `Voici les emails reçus aujourd\\'hui. Fais un résumé concis en 3 à 5 bullet points :\\n\\n${prompt}` }\n    ],\n    temperature: 0.5,\n    max_tokens: 400\n  })\n}}];"
      },
      "id": "c91f2597-d22e-4e7b-abae-6975ccfd2020",
      "name": "Préparer Groq",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        768,
        160
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer VOTRE_CLÉ_GROQ"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
