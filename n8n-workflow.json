    {
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nconst emails = staticData.emails ? JSON.parse(staticData.emails) : [];\nconst summary = items[0].json.choices?.[0]?.message?.content || 'Résumé non disponible.';\n\nreturn [{ json: {\n  generatedAt: new Date().toISOString(),\n  date: new Date().toISOString().split('T')[0],\n  summary,\n  emails\n} }];"
